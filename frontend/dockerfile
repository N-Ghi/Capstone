# Build stage
FROM node:24-slim AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

ARG VITE_API_BASE_URL
ARG VITE_GOOGLE_MAPS_API_KEY
ARG VITE_AZURE_TRANSLATOR_KEY
ARG VITE_AZURE_TRANSLATOR_REGION
ARG VITE_AZURE_TRANSLATOR_ENDPOINT
ARG VITE_API_TIMEOUT
ARG VITE_DEV

ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
ENV VITE_GOOGLE_MAPS_API_KEY=${VITE_GOOGLE_MAPS_API_KEY}
ENV VITE_AZURE_TRANSLATOR_KEY=${VITE_AZURE_TRANSLATOR_KEY}
ENV VITE_AZURE_TRANSLATOR_REGION=${VITE_AZURE_TRANSLATOR_REGION}
ENV VITE_AZURE_TRANSLATOR_ENDPOINT=${VITE_AZURE_TRANSLATOR_ENDPOINT}
ENV VITE_API_TIMEOUT=${VITE_API_TIMEOUT}
ENV VITE_DEV=${VITE_DEV}

RUN npm run build

# Production stage
FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]